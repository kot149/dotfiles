# Font
font-family = Inconsolata
font-family = Symbols Nerd Font Mono
font-codepoint-map = U+3000-U+30FF,U+4E00-U+9FFF,U+FF00-U+FFEF=Hiragino Sans
adjust-icon-height = 10%

# font-feature = -dlig
font-size = 17

alpha-blending = linear

# Cursor
adjust-cursor-thickness = 1

# Shell
shell-integration-features = no-cursor

# Window
window-save-state = always
confirm-close-surface = false

window-width = 180
window-height = 50

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true


# macos-titlebar-style = hidden
macos-window-shadow = false
macos-option-as-alt = true

# Keybindings
keybind = f1=toggle_command_palette
keybind = option+e=text:\x1be
keybind = option+g=text:\x1bg
keybind = ctrl+right=text:\x1b[1;5C
keybind = ctrl+left=text:\x1b[1;5D
keybind = alt+right=text:\x1b[1;3C
keybind = alt+left=text:\x1b[1;3D
keybind = ctrl+z=text:\x1a
keybind = ctrl+y=text:\x19
keybind = performable:ctrl+c=copy_to_clipboard

# macOS ではキーボード本体の設定で Ctrl/Cmd を入れ替えているため、物理 Ctrl は super として届く
# (Linux ではスワップせず物理 Ctrl = ctrl のまま)。
# Ghostty の操作はすべて super+shift に寄せ、物理 Ctrl 由来の super+X は Ctrl 相当の制御文字に
# 変換して下のレイヤ (Zellij / Neovim / シェル) へ送る。nvim 等は <C-*> だけで両 OS 対応できる。
keybind = super+right=text:\x1b[1;5C
keybind = super+left=text:\x1b[1;5D
keybind = super+z=text:\x1a
keybind = super+y=text:\x19
keybind = super+p=text:\x10
keybind = super+n=text:\x0e
keybind = super+s=text:\x13
keybind = super+x=text:\x18
keybind = super+e=text:\x05
keybind = super+/=text:\x1f

# super+X デフォルトを下のレイヤに通す
keybind = super+,=unbind
# super+c / super+v は例外: 物理 Ctrl+C / Ctrl+V でコピー&ペーストできるよう Ghostty に残す
keybind = performable:super+c=copy_to_clipboard:mixed
keybind = super+v=paste_from_clipboard
keybind = super+==unbind
keybind = super++=unbind
keybind = super+-=unbind
keybind = super+0=unbind
keybind = super+digit_1=unbind
keybind = super+1=unbind
keybind = super+digit_2=unbind
keybind = super+2=unbind
keybind = super+digit_3=unbind
keybind = super+3=unbind
keybind = super+digit_4=unbind
keybind = super+4=unbind
keybind = super+digit_5=unbind
keybind = super+5=unbind
keybind = super+digit_6=unbind
keybind = super+6=unbind
keybind = super+digit_7=unbind
keybind = super+7=unbind
keybind = super+digit_8=unbind
keybind = super+8=unbind
keybind = super+9=unbind
keybind = super+enter=unbind
keybind = super+q=unbind
keybind = super+k=unbind
keybind = super+a=unbind
keybind = super+home=unbind
keybind = super+end=unbind
keybind = super+j=unbind
keybind = super+w=unbind
keybind = super+t=unbind
keybind = super+d=unbind
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+arrow_up=unbind
keybind = super+arrow_down=unbind
keybind = super+f=unbind
keybind = super+g=unbind
keybind = super+backspace=unbind

# タブ移動: 物理 Ctrl+PageUp/Down (Ghostty 上は super) で左右のタブへ
keybind = super+page_up=previous_tab
keybind = super+page_down=next_tab

# Ghostty 操作は super+shift 系へ集約
keybind = super+shift+,=open_config
keybind = super+shift+==increase_font_size:1
keybind = super+shift+-=decrease_font_size:1
keybind = super+shift+0=reset_font_size
keybind = super+shift+digit_1=goto_tab:1
keybind = super+shift+1=goto_tab:1
keybind = super+shift+digit_2=goto_tab:2
keybind = super+shift+2=goto_tab:2
keybind = super+shift+digit_3=goto_tab:3
keybind = super+shift+3=goto_tab:3
keybind = super+shift+digit_4=goto_tab:4
keybind = super+shift+4=goto_tab:4
keybind = super+shift+digit_5=goto_tab:5
keybind = super+shift+5=goto_tab:5
keybind = super+shift+digit_6=goto_tab:6
keybind = super+shift+6=goto_tab:6
keybind = super+shift+digit_7=goto_tab:7
keybind = super+shift+7=goto_tab:7
keybind = super+shift+digit_8=goto_tab:8
keybind = super+shift+8=goto_tab:8
keybind = super+shift+9=last_tab
keybind = super+shift+enter=toggle_fullscreen
keybind = super+shift+q=quit
keybind = super+shift+k=clear_screen
keybind = super+shift+a=select_all
keybind = super+shift+home=scroll_to_top
keybind = super+shift+end=scroll_to_bottom
keybind = super+shift+page_up=scroll_page_up
keybind = super+shift+page_down=scroll_page_down
keybind = super+shift+j=scroll_to_selection
keybind = super+shift+n=new_window
keybind = super+shift+w=close_surface
keybind = super+shift+t=new_tab
keybind = super+shift+d=new_split:right
keybind = super+shift+[=goto_split:previous
keybind = super+shift+]=goto_split:next
keybind = super+shift+arrow_up=jump_to_prompt:-1
keybind = super+shift+arrow_down=jump_to_prompt:1
keybind = super+shift+f=start_search
keybind = super+shift+e=search_selection
keybind = super+shift+g=navigate_search:next
keybind = super+shift+backspace=text:\x15
