{{- $git_user_name := promptStringOnce . "git_user_name" "Git user.name (author for commits)" "kot149" -}}
{{- $git_user_email := promptStringOnce . "git_user_email" "Git user.email" "131101078+kot149@users.noreply.github.com" -}}
{{- $git_signing_key := promptStringOnce . "git_signing_key" "Path to SSH public key for signing (leave empty for ~/.ssh/id_ed25519_github_kot149.pub)" "" -}}
{{- $git_allowed_signers := promptStringOnce . "git_allowed_signers" "Path to allowed_signers (leave empty for ~/.ssh/allowed_signers)" "" -}}
[data]
git_user_name = {{ $git_user_name | quote }}
git_user_email = {{ $git_user_email | quote }}
git_signing_key = {{ $git_signing_key | quote }}
git_allowed_signers = {{ $git_allowed_signers | quote }}
git_editor = "code --wait"
git_commit_gpgsign = true
git_safe_directories = []
