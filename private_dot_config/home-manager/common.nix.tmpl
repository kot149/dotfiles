{ pkgs, nixClaudeCode, nixCodexCli, ... }:

let
  rtk = pkgs.callPackage ./rtk.nix { };
in
{
  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  # See https://search.nixos.org/packages
  home.packages = (with pkgs; [
    # dotfiles
    chezmoi

    # git
    git
    gh
    lazygit
    pre-commit
    act
    pinact
    actionlint
    delta

    # shell
    zsh
    oh-my-zsh
    sheldon
    starship
    direnv
    nix-direnv
    tree
    msedit
    ripgrep
    zoxide
    fzf
    fd
    bat
    eza

    # programming
    nodejs_24
    pnpm
    bun
    ni

    uv
    pyenv
    pipenv

    go

    rustup
    cargo-binstall
    cargo-make

    # db
    mysql84
    sqlfluff

    # ai
    nixClaudeCode
    nixCodexCli

    # misc
    curl
    wget
    wakeonlan

    # fonts
    inconsolata
    nerd-fonts.inconsolata
    nerd-fonts.symbols-only
  ]) ++ [ rtk ];

  programs.home-manager.enable = true;
  home.stateVersion = "25.11";
}
