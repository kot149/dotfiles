#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

session_name="${ZELLIJ_SESSION_NAME:-}"

if [[ -z "$session_name" ]]; then
  print -u2 "ZELLIJ_SESSION_NAMEを取得できませんでした。"
  exit 1
fi

lazygit_pane_filter='
  map(select(
    .is_plugin == false and
    .is_floating == true and
    .exited == false and
    (.terminal_command == "zellij-dev-lazygit" or .title == "lazygit" or .pane_command == "lazygit")
  ))
  | first
  | .id // empty
'

visible_lazygit_pane_id="$(
  zellij -s "$session_name" action list-panes --json 2>/dev/null \
    | jq -r "$lazygit_pane_filter"
)"

if [[ -n "$visible_lazygit_pane_id" ]]; then
  exec zellij -s "$session_name" action close-pane --pane-id "$visible_lazygit_pane_id"
fi

hidden_lazygit_pane_id="$(
  zellij -s "$session_name" action list-panes --all --json 2>/dev/null \
    | jq -r "$lazygit_pane_filter"
)"

if [[ -n "$hidden_lazygit_pane_id" ]]; then
  zellij -s "$session_name" action show-floating-panes >/dev/null
  exec zellij -s "$session_name" action focus-pane-id "$hidden_lazygit_pane_id"
fi

exec zellij -s "$session_name" action new-pane \
  --floating \
  --close-on-exit \
  --name "lazygit" \
  --x "10%" \
  --y "8%" \
  --width "80%" \
  --height "84%" \
  -- zellij-dev-lazygit
