{{- if eq .chezmoi.os "windows" -}}
#!/usr/bin/env pwsh
$ErrorActionPreference = "Stop"

# checksum: {{ include ".chezmoitemplates/codex/config.toml.tmpl" | sha256sum }}

Write-Host "Updating Codex config..."

$configFile = "{{ joinPath .chezmoi.homeDir ".codex/config.toml" }}"
$specFile = [System.IO.Path]::GetTempFileName()
$mergeScript = [System.IO.Path]::GetTempFileName()
$outputFile = [System.IO.Path]::GetTempFileName()

try {
  New-Item -ItemType Directory -Force -Path ([System.IO.Path]::GetDirectoryName($configFile)) | Out-Null

  @'
{{ include ".chezmoitemplates/codex/config.toml.tmpl" }}
'@ | Set-Content -LiteralPath $specFile -Encoding utf8NoBOM

  if (-not (Test-Path -LiteralPath $configFile)) {
    Copy-Item -LiteralPath $specFile -Destination $configFile
    Write-Host "Created $configFile"
    Write-Host "Done."
    exit 0
  }

  @'
#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = [
#   "tomlkit",
# ]
# ///

from pathlib import Path
import sys

from tomlkit import dumps, parse
from tomlkit.items import Table


def fail(message: str) -> None:
    print(f"Error: {message}", file=sys.stderr)
    raise SystemExit(1)


spec_path = Path(sys.argv[1])
config_path = Path(sys.argv[2])
output_path = Path(sys.argv[3])

spec_doc = parse(spec_path.read_text())
config_doc = parse(config_path.read_text())

# Apply managed top-level scalar keys while preserving unmanaged user settings.
for key, value in spec_doc.items():
    if isinstance(value, Table):
        continue
    config_doc[key] = value

tui_table = spec_doc.get("tui")
if not isinstance(tui_table, Table):
    fail("tui table not found in managed Codex config template")

managed_status_line = tui_table.get("status_line")
if managed_status_line is None:
    fail("status_line not found in managed Codex config template")

config_tui = config_doc.get("tui")
if config_tui is None:
    config_tui = {}
    config_doc["tui"] = config_tui
elif not isinstance(config_tui, Table):
    fail("existing tui value is not a TOML table")

config_tui["status_line"] = managed_status_line
output_path.write_text(dumps(config_doc))
'@ | Set-Content -LiteralPath $mergeScript -Encoding utf8NoBOM

  uv run --script $mergeScript $specFile $configFile $outputFile

  Move-Item -LiteralPath $outputFile -Destination $configFile -Force
  Write-Host "Merged managed settings into $configFile"

  Write-Host "Done."
}
finally {
  Remove-Item -LiteralPath $specFile, $mergeScript, $outputFile -Force -ErrorAction SilentlyContinue
}
{{- end -}}
