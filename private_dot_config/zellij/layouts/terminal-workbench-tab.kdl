layout {
    pane split_direction="vertical" size="78%" {
        pane size="20%" command="zellij-dev-yazi" name="Files"
        pane size="55%" stacked=true {
            pane name="Main" {
                focus true
            }
        }
        pane size="25%" stacked=true {
            pane name="Sub"
        }
    }
    pane size="22%" stacked=true {
        pane name="Terminal"
    }
}
