#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

session_name=""
force_new="false"
max_session_name_length=17

while (( $# > 0 )); do
  case "$1" in
    --new)
      force_new="true"
      ;;
    *)
      session_name="$1"
      ;;
  esac
  shift
done

if [[ -z "$session_name" ]]; then
  workspace_path="${PWD:A}"
  workspace_name="${workspace_path:t}"
  workspace_name="${workspace_name//[^[:alnum:]]/-}"
  workspace_name="${workspace_name#-}"
  workspace_name="${workspace_name%-}"

  if [[ -z "$workspace_name" ]]; then
    workspace_name="workspace"
  fi

  workspace_checksum="$(
    print -r -- "$workspace_path" | cksum | awk '{ print $1 }'
  )"
  workspace_hash="$(printf "%08x" "$workspace_checksum")"
  session_workspace="${workspace_name:0:8}"
  session_workspace="${session_workspace%-}"

  if [[ -z "$session_workspace" ]]; then
    session_workspace="work"
  fi

  session_name="d-${session_workspace}-${workspace_hash:0:6}"
fi

sessions="$(zellij list-sessions 2>/dev/null | sed -E 's/\x1b\[[0-9;]*[[:alpha:]]//g')"
base_session_name="$session_name"

if [[ "$force_new" == "true" ]]; then
  suffix=1

  while true; do
    if (( suffix == 1 )); then
      candidate_session_name="$base_session_name"
    else
      suffix_text="-${suffix}"
      candidate_prefix="${base_session_name:0:$(( max_session_name_length - ${#suffix_text} ))}"
      candidate_prefix="${candidate_prefix%-}"
      candidate_session_name="${candidate_prefix}${suffix_text}"
    fi

    session_line="$(print -r -- "$sessions" | grep -F "${candidate_session_name} [" | head -n 1)"
    if [[ -z "$session_line" ]]; then
      session_name="$candidate_session_name"
      break
    fi

    (( suffix++ ))
  done
else
  session_line="$(print -r -- "$sessions" | grep -F "${session_name} [" | head -n 1)"
fi

if [[ -n "$session_line" ]]; then
  if zellij attach --forget "$session_name"; then
    exit 0
  fi

  zellij delete-session --force "$session_name" >/dev/null 2>&1 || true
fi

exec zellij -n terminal-workbench -s "$session_name"
