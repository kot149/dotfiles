{{- $allow := list -}}
{{- range .agent_plain_allow -}}
  {{- $allow = append $allow . -}}
{{- end -}}
{{- range .agent_shell_allow -}}
  {{- $allow = append $allow (printf "Bash(%s)" .) -}}
  {{- $allow = append $allow (printf "Bash(rtk %s)" .) -}}
  {{- if hasSuffix " *" . -}}
    {{- $bare := trimSuffix " *" . -}}
    {{- $allow = append $allow (printf "Bash(%s)" $bare) -}}
    {{- $allow = append $allow (printf "Bash(rtk %s)" $bare) -}}
  {{- end -}}
  {{- if or (hasPrefix "pnpm " .) (hasPrefix "npm " .) (hasPrefix "yarn " .) -}}
    {{- $allow = append $allow (printf "Bash(corepack %s)" .) -}}
  {{- end -}}
{{- end -}}
{{- range .agent_shell_allow_no_rtk -}}
  {{- $allow = append $allow (printf "Bash(%s)" .) -}}
{{- end -}}
{{- $deny := list -}}
{{- range .agent_shell_deny -}}
  {{- $deny = append $deny (printf "Bash(%s)" .) -}}
  {{- $deny = append $deny (printf "Bash(rtk %s)" .) -}}
{{- end -}}
{
  "permissions": {
    "allow": {{ $allow | toPrettyJson | indent 4 | trim }},
    "deny": {{ $deny | toPrettyJson | indent 4 | trim }},
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-package-manager.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "cloudflare@cloudflare": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    }
  },
  "model": "claude-opus-4-7[1m]",
  "effortLevel": "medium",
  "awaySummaryEnabled": false
}
