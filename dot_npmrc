# npm: minimum release age (days)
# https://docs.npmjs.com/cli/v11/using-npm/config#min-release-age
min-release-age=3
# https://docs.npmjs.com/cli/v11/using-npm/config#ignore-scripts
ignore-scripts=true

# pnpm-specific settings live in pnpm's own config.yaml (see pnpm config get globalconfig).
# Keeping camelCase keys like `minimumReleaseAge` here would make npm error out on unknown config.
