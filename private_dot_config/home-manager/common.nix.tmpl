{ pkgs, nixClaudeCode, nixCodexCli, ... }:

let
  rtk = pkgs.callPackage ./rtk.nix { };
in
{
  home.username = "{{ .chezmoi.username }}";
  home.homeDirectory = "{{ .chezmoi.homeDir }}";

  # See https://search.nixos.org/packages
  home.packages = (with pkgs; [
    # dotfiles
    chezmoi

    # git
    git
    gh
    lazygit
    pre-commit
    act
    pinact
    actionlint
    delta

    # shell
    zsh
    oh-my-zsh
    sheldon
    starship
    direnv
    nix-direnv
    tree
    msedit
    ripgrep
    zoxide
    fzf
    fd
    bat
    eza
    superfile
    fresh-editor
    rip2
    jq
    yq

    # programming
    nodejs_24
    pnpm
    bun
    ni

    uv
    pyenv
    pipenv

    go

    rustup
    cargo-binstall
    cargo-make

    # db
    mysql84
    sqlfluff

    # ai
    nixClaudeCode
    nixCodexCli
    opencode

    # misc
    curl
    wget
    wakeonlan
    mise
    lazydocker
    btop
    google-cloud-sdk
    cloudflared
    tailscale

    # fonts
    inconsolata
    nerd-fonts.inconsolata
    nerd-fonts.symbols-only
  ]) ++ [ rtk ];

  programs.home-manager.enable = true;
  home.stateVersion = "25.11";

  xdg.configFile."nix/nix.conf".force = true;

  nix.package = pkgs.nix;

  nix.settings = {
    experimental-features = [ "nix-command" "flakes" ];
  };

  nix.gc = {
    automatic = true;
    dates = "weekly";
    options = "--delete-older-than 30d";
  };
}
