{{- if eq .chezmoi.os "windows" -}}
#!/bin/sh
{{- else -}}
#!/bin/bash
{{- end }}
set -euo pipefail

# checksum: {{ include ".chezmoitemplates/vscode/keybindings.json.tmpl" | sha256sum }}

echo Updating VSCode keybindings...

spec_file="$(mktemp)"
merge_script="$(mktemp)"
{{- if eq .chezmoi.os "darwin" }}
code_target="{{ joinPath .chezmoi.homeDir "Library/Application Support/Code/User/keybindings.json" }}"
cursor_target="{{ joinPath .chezmoi.homeDir "Library/Application Support/Cursor/User/keybindings.json" }}"
{{- else if eq .chezmoi.os "linux" }}
code_target="{{ joinPath .chezmoi.homeDir ".config/Code/User/keybindings.json" }}"
cursor_target="{{ joinPath .chezmoi.homeDir ".config/Cursor/User/keybindings.json" }}"
{{- else if eq .chezmoi.os "windows" }}
code_target="{{ joinPath .chezmoi.homeDir "AppData/Roaming/Code/User/keybindings.json" }}"
cursor_target="{{ joinPath .chezmoi.homeDir "AppData/Roaming/Cursor/User/keybindings.json" }}"
{{- else }}
echo "Unsupported OS: {{ .chezmoi.os }}"
exit 0
{{- end }}

cleanup() {
  rm -f "$spec_file" "$merge_script"
}
trap cleanup EXIT

mkdir -p "$(dirname "$code_target")" "$(dirname "$cursor_target")"
cat >"$spec_file" <<'JSON'
{{ include ".chezmoitemplates/vscode/keybindings.json.tmpl" }}
JSON

cat >"$merge_script" <<'PY'
#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.9"
# dependencies = [
#   "json5",
# ]
# ///

import json
from pathlib import Path
import sys

import json5

OS_NAME = "{{ .chezmoi.os }}"


def load_json_with_comments(path: Path):
    if not path.exists():
        return []

    raw = path.read_text(encoding="utf-8")
    if not raw.strip():
        return []

    return json5.loads(raw)


def matches_rule(item, rule):
    if not isinstance(item, dict):
        return False

    if "key" in rule and item.get("key") != rule["key"]:
        return False

    if "keys" in rule and item.get("key") not in rule["keys"]:
        return False

    if "command" in rule and item.get("command") != rule["command"]:
        return False

    if "commands" in rule and item.get("command") not in rule["commands"]:
        return False

    if "args" in rule and item.get("args") != rule["args"]:
        return False

    when = str(item.get("when", ""))

    if "when_contains" in rule and not all(text in when for text in rule["when_contains"]):
        return False

    if "when_not_contains" in rule and any(text in when for text in rule["when_not_contains"]):
        return False

    return True


def select_grouped_items(spec, field_name):
    grouped_items = spec.get(field_name, {})
    if not isinstance(grouped_items, dict):
        raise SystemExit(f"{spec_path} field '{field_name}' must be a JSON object")

    selected = []
    for group_name in ("common", OS_NAME):
        items = grouped_items.get(group_name, [])
        if not isinstance(items, list):
            raise SystemExit(f"{spec_path} field '{field_name}.{group_name}' must be a JSON array")
        selected.extend(items)
    return selected


spec_path = Path(sys.argv[1])
spec = json.loads(spec_path.read_text(encoding="utf-8"))
managed_rules = select_grouped_items(spec, "managed")
desired = select_grouped_items(spec, "desired")

for arg in sys.argv[2:]:
    target = Path(arg)
    current = load_json_with_comments(target)

    if not isinstance(current, list):
        raise SystemExit(f"{target} must contain a JSON array")

    filtered = [
        item
        for item in current
        if not any(matches_rule(item, rule) for rule in managed_rules)
    ]

    merged = filtered + desired

    with target.open("w", encoding="utf-8") as f:
        json.dump(merged, f, indent=2)
        f.write("\n")

    print(f"Merged managed keybindings into {target}")
PY

chmod +x "$merge_script"
"$merge_script" "$spec_file" "$code_target" "$cursor_target"

echo Done.
