{{- $shellAllow := list -}}
{{- range .agent_shell_allow -}}
  {{- $shellAllow = append $shellAllow . -}}
{{- end -}}
{{- $scriptPrefixes := list "npm run" "pnpm run" "pnpm" "yarn run" "yarn" "bun run" "bun" -}}
{{- range .agent_shell_allow_js_scripts -}}
  {{- $script := . -}}
  {{- range $scriptPrefixes -}}
    {{- $shellAllow = append $shellAllow (printf "%s %s *" . $script) -}}
  {{- end -}}
{{- end -}}
{{- $binPrefixes := list "npx" "pnpm exec" "pnpm dlx" "pnpm" "yarn exec" "yarn dlx" "yarn" "bunx" "bun x" "bun" -}}
{{- range .agent_shell_allow_js_bins -}}
  {{- $bin := . -}}
  {{- $shellAllow = append $shellAllow (printf "%s *" $bin) -}}
  {{- range $binPrefixes -}}
    {{- $shellAllow = append $shellAllow (printf "%s %s *" . $bin) -}}
  {{- end -}}
{{- end -}}
{{- $allow := list -}}
{{- range .agent_plain_allow -}}
  {{- $allow = append $allow . -}}
{{- end -}}
{{- range $shellAllow -}}
  {{- $allow = append $allow (printf "Bash(%s)" .) -}}
  {{- $allow = append $allow (printf "Bash(rtk %s)" .) -}}
  {{- if hasSuffix " *" . -}}
    {{- $bare := trimSuffix " *" . -}}
    {{- $allow = append $allow (printf "Bash(%s)" $bare) -}}
    {{- $allow = append $allow (printf "Bash(rtk %s)" $bare) -}}
  {{- end -}}
  {{- if or (hasPrefix "pnpm " .) (hasPrefix "npm " .) (hasPrefix "yarn " .) -}}
    {{- $allow = append $allow (printf "Bash(corepack %s)" .) -}}
  {{- end -}}
{{- end -}}
{{- range .agent_shell_allow_no_rtk -}}
  {{- $allow = append $allow (printf "Bash(%s)" .) -}}
{{- end -}}
{{- $deny := list -}}
{{- range .agent_shell_deny -}}
  {{- $deny = append $deny (printf "Bash(%s)" .) -}}
  {{- $deny = append $deny (printf "Bash(rtk %s)" .) -}}
{{- end -}}
{
  "permissions": {
    "allow": {{ $allow | toPrettyJson | indent 4 | trim }},
    "deny": {{ $deny | toPrettyJson | indent 4 | trim }},
    "defaultMode": "acceptEdits"
  },
  "autoMode": {
    "soft_deny": [
      "$defaults",
      "Do not run `git push` (in any form, including `git push --force`, `git push -u`, `gh repo sync`, or pushing tags) unless the user has explicitly instructed pushing in this conversation.",
      "Do not create or update GitHub issues (`gh issue create`, `gh issue edit`, `gh issue close`, `gh issue reopen`, or the equivalent REST/GraphQL API calls) unless the user has explicitly instructed the create/update in this conversation.",
      "Do not create or update GitHub pull requests (`gh pr create`, `gh pr edit`, `gh pr merge`, `gh pr close`, `gh pr reopen`, `gh pr ready`, or the equivalent REST/GraphQL API calls) unless the user has explicitly instructed the create/update in this conversation.",
      "Do not create or update GitHub releases (`gh release create`, `gh release edit`, `gh release delete`, or the equivalent REST/GraphQL API calls) unless the user has explicitly instructed the create/update in this conversation.",
      "Do not post comments to GitHub issues or pull requests (`gh issue comment`, `gh pr comment`, `gh pr review`, or any `gh api` / `curl` call that writes to `/repos/*/issues/*/comments`, `/repos/*/pulls/*/comments`, `/repos/*/pulls/*/reviews`, or similar comment/review endpoints) unless the user has explicitly instructed the comment in this conversation."
    ]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_AFK_TIMEOUT_MS": "2147483647"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-package-manager.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "cloudflare@cloudflare": true,
    "compact-plus@compact-plus-local": true
  },
  "extraKnownMarketplaces": {
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "compact-plus-local": {
      "source": {
        "source": "github",
        "repo": "u-ichi/compact-plus"
      }
    }
  },
  "model": "claude-opus-4-7[1m]",
  "effortLevel": "medium",
  "awaySummaryEnabled": false
}
