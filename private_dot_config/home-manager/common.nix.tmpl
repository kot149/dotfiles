{ config, lib, pkgs, nixClaudeCode, nixCodexCli, nixHerdr, nixHunk, ... }:

let
  basePackages = (with pkgs; [
    # nix
    nix

    # dotfiles
    chezmoi

    # git
    git
    gh
    lazygit
    pre-commit
    act
    pinact
    actionlint
    git-filter-repo

    # shell
    zsh
    oh-my-zsh
    sheldon
    starship
    direnv
    nix-direnv
    tree
    msedit
    ripgrep
    zoxide
    fzf
    fd
    bat
    moor
    eza
    superfile
    fresh-editor
    rip2
    jq
    yq
    yazi
    zellij

    # programming
    cmake
    nodejs_24
    pnpm
    bun
    ni

    uv
    pyenv
    pipenv

    go

    rustup
    cargo-binstall
    cargo-make

    # db
    mysql84
    sqlfluff

    # editor
    neovim
    tree-sitter
    lua-language-server
    nil
    stylua

    # ai
    nixClaudeCode
    nixCodexCli
    nixHerdr
    nixHunk
    opencode
    rtk

    # misc
    curl
    wget
    wakeonlan
    mise
    lazydocker
    btop
    cloudflared
    tailscale
    devcontainer
    glow
    rich-cli
    tdf

    # fonts
    inconsolata
    nerd-fonts.inconsolata
    nerd-fonts.symbols-only
  ]);
  denyPackages = config.localDeny.packages;
in
{
  options.localDeny.packages = lib.mkOption {
    type = lib.types.listOf lib.types.package;
    default = [ ];
    description = "Packages to remove from common home.packages";
  };

  options.localAllowUnfree.packages = lib.mkOption {
    type = lib.types.listOf lib.types.str;
    default = [ ];
    description = "Package names to permit under allowUnfreePredicate (merged across modules)";
  };

  config = {
    home.username = "{{ .chezmoi.username }}";
    home.homeDirectory = "{{ .chezmoi.homeDir }}";

    localAllowUnfree.packages = [
      "discord"
      "ngrok"
      "terraform"
    ];

    nixpkgs.config.allowUnfreePredicate = pkg:
      builtins.elem (lib.getName pkg) config.localAllowUnfree.packages;

    # See https://search.nixos.org/packages
    home.packages = lib.lists.subtractLists denyPackages basePackages;

    programs.home-manager.enable = true;
    home.stateVersion = "25.11";

    xdg.configFile."nix/nix.conf".force = true;

    nix.package = pkgs.nix;

    nix.settings = {
      experimental-features = [ "nix-command" "flakes" ];
      extra-substituters = [
        "https://codex-cli.cachix.org"
        "https://nix-community.cachix.org"
        "https://nixpkgs-terraform.cachix.org"
      ];
      extra-trusted-public-keys = [
        "codex-cli.cachix.org-1:1Br3H1hHoRYG22n//cGKJOk3cQXgYobUel6O8DgSing="
        "nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs="
        "nixpkgs-terraform.cachix.org-1:8Sit092rIdAVENA3ZVeH9hzSiqI/jng6JiCrQ1Dmusw="
      ];
    };

    programs.nh = {
      enable = true;
      clean = {
        enable = true;
        dates = "weekly";
        extraArgs = "--keep-since 30d --keep 1";
      };
    };
  };
}
