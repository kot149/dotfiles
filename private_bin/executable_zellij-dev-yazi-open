#!/usr/bin/env zsh

emulate -L zsh
setopt pipefail

target="${1:-}"
session_name="${ZELLIJ_SESSION_NAME:-}"

if [[ -z "$target" ]]; then
  exit 0
fi

if [[ -z "$session_name" ]]; then
  print -u2 "ZELLIJ_SESSION_NAMEを取得できませんでした。"
  exit 1
fi

current_tab_id="$(
  zellij -s "$session_name" action current-tab-info --json 2>/dev/null \
    | jq -r '.tab_id // empty'
)"

if [[ -z "$current_tab_id" ]]; then
  print -u2 "current tabを取得できませんでした。"
  exit 1
fi

main_pane_id="$(
  zellij -s "$session_name" action list-panes --json 2>/dev/null \
    | jq -r --argjson tab_id "$current_tab_id" '
        map(select(
          .is_plugin == false and
          .tab_id == $tab_id and
          .title == "Main" and
          .exited == false
        ))
        | first
        | .id // empty
      '
)"

if [[ -z "$main_pane_id" ]]; then
  print -u2 "Mainペインが見つかりませんでした。"
  exit 1
fi

escaped_target="$(printf '%q' "$target")"

zellij -s "$session_name" action focus-pane-id "$main_pane_id" >/dev/null
zellij -s "$session_name" action write-chars -p "$main_pane_id" "vim $escaped_target" >/dev/null
exec zellij -s "$session_name" action send-keys -p "$main_pane_id" Enter
